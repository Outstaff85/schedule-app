{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".github/**",
      "google-apps-script.js",
      "SETUP.md",
      "README.md",
      "node_modules/**"
    ],
    "headers": [
      {
        "source": "/service-worker.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "/**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "/**/*.png",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/punch",
        "destination": "/worker-punch.html"
      },
      {
        "source": "/admin",
        "destination": "/schedule-manager.html"
      }
    ],
    "cleanUrls": false,
    "trailingSlash": false
  }
}
